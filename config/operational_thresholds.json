{
    "entity_resolution": {
        "suffix_regex": "(?i)\\b(inc|llc|corp|incorporated|group|co|ltd|international)\\b|[.,_]",
        "levenshtein_threshold": 2
    },
    "drift_monitoring": {
        "historical_average_pct": 65.0,
        "threshold_deviation_pct": 15.0
    },
    "pipeline": {
        "app_name_ingestion": "Iceberg-Boto3-LLM-Deduplication-Pipeline",
        "app_name_ml": "Iceberg-SparkML-Training-Service",
        "iceberg_catalog": "local_cat",
        "iceberg_db": "db",
        "iceberg_table": "corporate_registry",
        "temp_view_name": "incoming_batch_records",
        "warehouse_type": "hadoop"
    },
    "ml_training": {
        "random_split_ratio": [0.8, 0.2],
        "random_seed": 42,
        "lr_max_iterations": 10,
        "profit_threshold": 100000.0,
        "feature_cols": ["revenue", "supplier_count"],
        "target_col": "high_profit_indicator",
        "baseline_accuracy": 0.85
    },
    "spark_config": {
        "iceberg_package": "org.apache.iceberg:iceberg-spark-runtime-3.4_2.12:1.3.1",
        "hadoop_aws_package": "org.apache.hadoop:hadoop-aws:3.3.4",
        "s3a_endpoint_suffix": "amazonaws.com"
    },
    "mlflow": {
        "experiment_name": "Corporate_Profitability_Analysis"
    },
    "data_quality": {
        "min_avg_revenue": 10000
    },
    "schema": {
        "source_1_columns": ["corporate_name_S1", "address", "activity_places", "top_suppliers"],
        "source_2_columns": ["corporate_name_S2", "main_customers", "revenue", "profit"]
    }
}